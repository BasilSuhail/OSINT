# Copy to .env and fill. Never commit .env.

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# FRED API (free registration: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# NASA FIRMS MAP_KEY (free registration: https://firms.modaps.eosdis.nasa.gov/api/area/)
FIRMS_MAP_KEY=

# Pushover (optional, for alerting)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Frontend (Next.js generated by v0) — read from Supabase REST
# See docs/frontend/README.md for setup. These two vars also live in the
# frontend repo's own .env.local; they are listed here so a fresh contributor
# sees the whole picture.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
