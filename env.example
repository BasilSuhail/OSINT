# Copy to .env and fill. Never commit .env.

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# FRED API (free registration: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Pushover (optional, for alerting)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
