# Copy to .env and fill. Never commit .env.

# Postgres
#
# For local docker (default): leave POSTGRES_HOST=localhost and pick any strong
# POSTGRES_PASSWORD. The docker-compose stack reads this password too.
#
# For Supabase (managed Postgres): set POSTGRES_HOST to your Supabase host
# (db.xxxxxxxx.supabase.co), POSTGRES_DB=postgres, POSTGRES_USER=postgres,
# and POSTGRES_PASSWORD to your Supabase database password.
# See supabase/README.md for the full setup.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# FRED API (free registration: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# NASA FIRMS MAP_KEY (free registration: https://firms.modaps.eosdis.nasa.gov/api/area/)
FIRMS_MAP_KEY=

# Pushover (optional, for alerting)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
