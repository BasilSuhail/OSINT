# Copy to .env and fill. Never commit .env.

# Postgres
#
# For local docker (default): leave POSTGRES_HOST=localhost and pick any strong
# POSTGRES_PASSWORD. The docker-compose stack reads this password too.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# FRED API (free registration: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# NASA FIRMS MAP_KEY (free registration: https://firms.modaps.eosdis.nasa.gov/api/area/)
FIRMS_MAP_KEY=

# ACLED API (account-gated; never commit real credentials)
ACLED_EMAIL=
ACLED_API_KEY=

# EM-DAT CSV export/import path (local file, never commit raw licensed data)
EMDAT_CSV_PATH=

# Optional cyber IP geolocation for abuse.ch rows. Bounded per fetch.
CYBER_GEO_ENABLED=true
CYBER_GEO_MAX_LOOKUPS=25

# Pushover (optional, for alerting)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Local storage — all DB/redis/archive data lives here (one folder).
# Laptop: leave default. Pi/external HDD: set an absolute path, e.g. /mnt/raid/osint/data
OSINT_DATA_DIR=./data

# Retention windows (days). Defaults keep only the latest few days.
RETENTION_GDELT_DAYS=2
RETENTION_NEWS_DAYS=3
RETENTION_HAZARD_DAYS=2

# Frontend → local read API (replaces Supabase REST/realtime).
# See docs/frontend/README.md for setup.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Browser origins allowed to call the API (comma-separated). Default localhost.
# For LAN/Pi/Tailscale, add the dashboard origin, e.g. http://pi.local:3000
API_CORS_ORIGINS=http://localhost:3000

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
